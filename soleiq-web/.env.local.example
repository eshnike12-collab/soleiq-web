# Copy this file to `.env.local` and fill in values from your Supabase project.
# Both values are safe to expose in browser code (they're public-by-design).
# RLS on the schema enforces actual access control.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR-PUBLISHABLE-KEY
# Legacy projects may use this variable instead:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Without the Supabase values, saved cloud history is unavailable.

# Server only. Never prefix this key with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-API-KEY
# Optional vision-capable model override. Defaults to claude-sonnet-4-6.
# ANTHROPIC_VISION_MODEL=claude-sonnet-4-6

# Legacy localhost AI integration retained on feat/localhost-ai-integration.
AI_BASE_URL=http://localhost:8000
# Server only. Used by the legacy /api/analyze storage path.
SUPABASE_SERVICE_ROLE_KEY=
