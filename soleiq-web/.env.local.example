# Copy this file to `.env.local` and fill in values from your Supabase project.
# Both values are safe to expose in browser code (they're public-by-design).
# RLS on the schema enforces actual access control.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# When unset, the app falls back to in-memory + sessionStorage only — useful
# for local demos without a Supabase project.

# ---------------------------------------------------------------------------
# AI service (foundation model + calibrated classifier) — SERVER-ONLY.
# The browser calls same-origin /api/analyze, which forwards here. Prod:
# set to https://api.soleiqhealth.com or wherever the AI is hosted.
# ---------------------------------------------------------------------------
AI_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Phase 6: server-only service-role key used by /api/analyze for the
# Supabase Storage upload + `scans` insert. NEVER prefix with NEXT_PUBLIC_.
# Leave blank while running Phase 5 alone.
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=
